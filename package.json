{
    "name": "qz-tray",
    "version": "2.2.6",
    "description": "Connects a web client to the QZ Tray software.  Enables printing and device communication from javascript. ",
    "main": "dist/qz-next.js",
    "module": "dist/qz-next.mjs",
    "types": "dist/types/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/types/index.d.ts",
            "import": "./dist/qz-next.mjs",
            "require": "./dist/qz-next.js",
            "default": "./dist/qz-next.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "src-next"
    ],
    "sideEffects": false,
    "browser": {
        "path": false,
        "lna": false
    },
    "scripts": {
        "build": "node scripts/build.mjs",
        "build:dev": "node scripts/build.mjs --dev",
        "build:next": "node scripts/build-next.mjs",
        "build:next:dev": "node scripts/build-next.mjs --dev",
        "build:all": "npm run build && npm run build:next && npm run types",
        "typecheck": "tsc --noEmit",
        "types": "tsc",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test:unit": "node scripts/units.mjs",
        "test": "node scripts/verify.mjs && node scripts/units.mjs"
    },
    "devDependencies": {
        "esbuild": "^0.25.0",
        "prettier": "^3.9.1",
        "typescript": "^5.9.3"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/qzind/tray.git"
    },
    "keywords": [
        "Printing",
        "USB",
        "Serial",
        "RS232",
        "USB",
        "Scales",
        "Zebra",
        "Epson",
        "Star",
        "Citizen",
        "BOCA"
    ],
    "author": "QZ Industries, LLC",
    "license": "LGPL-2.1",
    "bugs": {
        "url": "https://github.com/qzind/tray/issues"
    },
    "homepage": "https://github.com/qzind/tray#readme"
}
